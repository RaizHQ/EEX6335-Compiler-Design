Grammar

    0 $accept: prog $end

    1 prog: classOrImplOrFunc_ZM

    2 classOrImplOrFunc_ZM: classOrImplOrFunc classOrImplOrFunc_ZM
    3                     | ε

    4 classOrImplOrFunc: classDecl
    5                  | implDef
    6                  | funcDef

    7 classDecl: CLASS ID isa_Id_ZO '{' visibility_memberDecl_ZM '}' ';'

    8 isa_Id_ZO: ISA ID commaID_ZM
    9          | ε

   10 commaID_ZM: ',' ID commaID_ZM
   11           | ε

   12 visibility_memberDecl_ZM: visibility memberDecl visibility_memberDecl_ZM
   13                         | ε

   14 implDef: IMPLEMENT ID '{' funcDef_ZM '}'

   15 funcDef_ZM: funcDef funcDef_ZM
   16           | ε

   17 funcDef: funcHead funcBody

   18 funcHead: FUNC ID '(' fParams ')' ARROW_OP returnType
   19         | CONSTRUCT '(' fParams ')'

   20 funcBody: '{' varDeclOrStmt_ZM '}'

   21 visibility: PUBLIC
   22           | PRIVATE

   23 memberDecl: funcDecl
   24           | attributeDecl

   25 funcDecl: funcHead ';'

   26 attributeDecl: ATTRIBUTE varDecl

   27 localVarDecl: LOCAL varDecl

   28 varDecl: ID ':' type arraySize_ZM ';'

   29 arraySize_ZM: arraySize arraySize_ZM
   30             | ε

   31 arraySize: '[' LITERAL_INTEGER ']'
   32          | '[' ']'

   33 varDeclOrStmt_ZM: varDeclOrStmt varDeclOrStmt_ZM
   34                 | ε

   35 varDeclOrStmt: localVarDecl
   36              | statement

   37 statement: matchedStmt
   38          | unmatchedStmt

   39 matchedStmt: variable assignOp expr ';'
   40            | functionCall ';'
   41            | IF '(' relExpr ')' THEN matchedStmt ELSE matchedStmt ';'
   42            | WHILE '(' relExpr ')' matchedStmt ';'
   43            | READ '(' variable ')' ';'
   44            | WRITE '(' expr ')' ';'
   45            | RETURN '(' expr ')' ';'
   46            | '{' statement_ZM '}'

   47 unmatchedStmt: IF '(' relExpr ')' THEN statement
   48              | IF '(' relExpr ')' THEN matchedStmt ELSE unmatchedStmt ';'
   49              | WHILE '(' relExpr ')' unmatchedStmt ';'

   50 statement_ZM: statement statement_ZM
   51             | ε

   52 expr: relExpr

   53 relExpr: arithExpr relOp arithExpr
   54        | arithExpr

   55 arithExpr: arithExpr addOp term
   56          | term

   57 term: term multOp factor
   58     | factor

   59 factor: variable
   60       | functionCall
   61       | LITERAL_INTEGER
   62       | LITERAL_FLOAT
   63       | '(' arithExpr ')'
   64       | NOT factor
   65       | '-' factor
   66       | '+' factor

   67 variable: primaryVar suffix_ZM

   68 primaryVar: idOrSelf

   69 idOrSelf: ID
   70         | SELF

   71 suffix_ZM: suffix suffix_ZM
   72          | indice_ZM

   73 suffix: indice_ZM '.' idOrSelf
   74       | '(' aParams ')' '.' idOrSelf

   75 indice_ZM: indice indice_ZM
   76          | ε

   77 indice: '[' arithExpr ']'

   78 functionCall: primaryVar '(' aParams ')'

   79 fParams: ID ':' type arraySize_ZM fParamsTail_ZM
   80        | ε

   81 fParamsTail_ZM: fParamsTail fParamsTail_ZM
   82               | ε

   83 fParamsTail: ',' ID ':' type arraySize_ZM

   84 aParams: expr aParamsTail_ZM
   85        | ε

   86 aParamsTail_ZM: aParamsTail aParamsTail_ZM
   87               | ε

   88 aParamsTail: ',' expr

   89 type: INTEGER
   90     | FLOAT
   91     | ID

   92 returnType: type
   93           | VOID

   94 assignOp: ASSIGN_OP

   95 relOp: EQ_OP
   96      | '<'
   97      | '>'
   98      | NE_OP
   99      | LE_OP
  100      | GE_OP

  101 addOp: '+'
  102      | '-'
  103      | OR

  104 multOp: '*'
  105       | '/'
  106       | AND


